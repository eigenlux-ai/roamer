<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required to enumerate active SIMs (SubscriptionManager); requested dynamically at runtime -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- Phase-2 region override: list installed apps in the "selected apps" picker so the user can pick
         which apps' region follows the primary SIM. Roamer is sideloaded (no Play policy), and the
         locale is written through Shizuku, not this permission. -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- Android 14/16 override path: launch instrumentation targeting our own package, adopting shell permissions to perform the override -->
    <instrumentation
        android:name="com.eigenlux.roamer.core.PrivilegedOverrideInstrumentation"
        android:targetPackage="${applicationId}" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Roamer">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Roamer.Splash"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:multiprocess="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />
    </application>

</manifest>